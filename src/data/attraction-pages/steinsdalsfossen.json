      "bodyHtml": "<div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\">\n              <a href=\"/attractions/costa-del-skartveit\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    斯\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">斯卡特维特海岸</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Costa del Skartveit</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/lillehammer-norway-folk-museum-maihaugen\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    利\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">利勒哈默尔</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Lillehammer</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/glacier-museum\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    冰\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">冰川博物馆</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Glacier Museum</p>\n                  </div>\n                </div>\n              </a>\n            </div>",

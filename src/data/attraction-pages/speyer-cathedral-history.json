      "bodyHtml": "<div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\">\n              <a href=\"/attractions/quedlinburg-old-town-history\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    奎\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">奎德林堡老城</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Quedlinburg</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/zons\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    措\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">措恩斯</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Zons</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/blankenburg-harz-city\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    布\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">布兰肯堡 (哈茨山脉)</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Blankenburg (Harz)</p>\n                  </div>\n                </div>\n              </a>\n            </div>",

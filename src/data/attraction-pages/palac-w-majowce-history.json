      "title": "猜你喜欢",
      "bodyHtml": "<div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\">\n              <a href=\"/attractions/farma-iluzji-poland\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    幻\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">幻想农场 - 教育娱乐公园</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Farma Iluzji - Edukacyjny Park Rozrywki</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/fragment-of-ghetto-wall-history\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    隔\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">隔都墙遗址片段</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Fragment of Ghetto Wall</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/brama-krakowska\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    克\n                  </div>\n                  <div class=\"p-4\">\n        
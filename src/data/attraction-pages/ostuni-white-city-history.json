      "title": "猜你喜欢",
      "bodyHtml": "<div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\">\n              <a href=\"/attractions/borghetto-sul-mincio\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    博\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">博尔盖托</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Borghetto sul Mincio</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/san-gimignano-towers-history\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    圣\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">圣吉米尼亚诺百塔之城</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">San Gimignano</p>\n                  </div>\n                </div>\n              </a>\n              <a href=\"/attractions/alba-piedmont-history\" class=\"block group\">\n                <div class=\"bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md transition-all duration-300\">\n                  <div class=\"h-32 bg-gray-100 flex items-center justify-center text-4xl font-serif text-gray-300\">\n                    阿\n                  </div>\n                  <div class=\"p-4\">\n                    <h4 class=\"font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-1\">阿尔巴</h4>\n                    <p class=\"text-sm text-gray-500 mt-1 line-clamp-1\">Alba</p>\n                  </div>\n                </div>\n              </a>\n            </div>",
